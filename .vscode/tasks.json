{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install requirements",
      "type": "shell",
      "command": "uv pip install -r requirements-all.txt",
      "problemMatcher": []
    },
    {
      "label": "Build and install midealocal lib",
      "type": "shell",
      "command": "rm -rf dist/ && uv run python -m build && uv pip install dist/midea_local*.whl",
      "problemMatcher": []
    },
    {
      "label": "Generate code coverage report",
      "type": "shell",
      "command": "uv run python -m pytest --rootdir . --cov=midealocal --cov-report term-missing ./tests/",
      "problemMatcher": []
    }
  ]
}
